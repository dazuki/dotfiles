{
    // window
    "window.title": "${rootName}",

    // editor
    "editor.lineNumbers": "off",
    "editor.minimap.enabled": false,
    "editor.folding": false,
    "editor.guides.indentation": false,
    "editor.renderLineHighlight": "none",
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.mouseWheelZoom": true,
    "editor.fontFamily": "JetBrainsMono Nerd Font",
    "editor.fontWeight": 500,
    "editor.fontSize": 16,
    "editor.formatOnSave": true,
    "editor.indentSize": 4,
    "editor.tabSize": 4,
    "editor.lightbulb.enabled": "off",
    "editor.glyphMargin": false,
    "editor.stickyScroll.scrollWithEditor": false,
    "editor.hover.sticky": false,
    "editor.stickyScroll.enabled": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.scrollbar.vertical": "hidden",
    "editor.scrollbar.verticalScrollbarSize": 0,

    // workbench
    "workbench.iconTheme": "material-icon-theme",
    "workbench.sideBar.location": "right",
    "workbench.startupEditor": "none",
    "workbench.colorTheme": "One Monokai",
    "workbench.statusBar.visible": true,
    "workbench.tree.enableStickyScroll": false,

    // terminal
    "terminal.integrated.defaultProfile.linux": "zsh",
    "terminal.integrated.fontSize": 16,

    // git
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "git.openRepositoryInParentFolders": "never",

    // gitlens
    "gitlens.currentLine.enabled": false,
    "gitlens.hovers.currentLine.over": "annotation",
    "gitlens.codeLens.enabled": false,
    "gitlens.hovers.enabled": false,

    // source control
    "scm.diffDecorations": "overview",

    // css
    "css.lint.unknownAtRules": "ignore",

    // prettier
    "prettier.tabWidth": 4,

    // tw fold
    "tailwind-fold.unfoldIfLineSelected": true,
    "tailwind-fold.autoFold": true,
    "tailwind-fold.supportedLanguages": [
        "html",
        "typescriptreact",
        "javascriptreact",
        "typescript",
        "javascript",
        "vue-html",
        "vue",
        "php",
        "blade",
        "markdown",
        "coffeescript",
        "svelte",
        "astro",
        "erb"
    ],

    // file specific
    "[blade]": {
        "editor.defaultFormatter": "shufo.vscode-blade-formatter"
    },
    "[astro]": {
        "editor.defaultFormatter": "astro-build.astro-vscode"
    },
    "[php]": {
        "editor.linkedEditing": true,
        "editor.defaultFormatter": "open-southeners.laravel-pint",
        "laravel-pint.enable": true
    },

    // apc
    "apc.electron": {},
    "apc.activityBar": {
        "size": 40,
        "itemSize": 40,
        "itemMargin": 0
    },
    "apc.stylesheet": {
        "*": "font-family: JetBrainsMono Nerd Font",
        ".editor .title": "background: transparent !important",
        ".actions-container.highlight-toggled": "display: none",
        ".editor .scrollbar .slider": "visibility: hidden",
        ".editor .scrollbar:hover .slider": "visibility: initial",
        ".part.sidebar.right.pane-composite-part": "height: 100%",
        ".monaco-list-rows": "font-size: 14px",
        ".tab.tab-actions-right.sizing-fit.has-icon.tab-border-bottom": "border: 1px solid #222 !important;--tab-border-bottom-color: none !important"
    },
    "apc.statusBar": {
        "position": "bottom"
    },

    // other
    "redhat.telemetry.enabled": false,
    "breadcrumbs.enabled": false
}
