{
  // window & other
  "window.title": "${rootName}",
  "window.commandCenter": false,
  //"window.zoomLevel": 0.5,
  "window.menuBarVisibility": "toggle",
  "breadcrumbs.enabled": false,

  // editor, workbench, explorer
  "editor.lineNumbers": "on",
  "editor.minimap.enabled": false,
  "editor.folding": false,
  "editor.guides.indentation": false,
  "editor.renderLineHighlight": "none",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.mouseWheelZoom": true,
  "editor.fontFamily": "'JetBrainsMono Nerd Font'",
  "editor.lineHeight": 1.8,
  "editor.smoothScrolling": true,
  "editor.fontLigatures": true,
  "editor.fontWeight": 600,
  "editor.fontSize": 16,
  "editor.formatOnSave": true,
  "editor.indentSize": 4,
  "editor.tabSize": 4,
  "editor.lightbulb.enabled": "off",
  "editor.glyphMargin": false,
  "editor.stickyScroll.scrollWithEditor": false,
  "editor.hover.sticky": false,
  "editor.stickyScroll.enabled": false,
  "editor.hideCursorInOverviewRuler": true,
  "editor.scrollbar.horizontal": "visible",
  "editor.scrollbar.horizontalScrollbarSize": 12,
  "editor.scrollbar.vertical": "visible",
  "editor.scrollbar.verticalScrollbarSize": 12,
  "editor.mouseWheelScrollSensitivity": 3,
  "workbench.iconTheme": "material-icon-theme",
  "workbench.startupEditor": "none",
  "workbench.statusBar.visible": true,
  "workbench.tree.enableStickyScroll": false,
  "workbench.colorTheme": "One Dark Pro Mix",
  "workbench.layoutControl.enabled": false,
  "explorer.sortOrder": "default",

  // terminal
  "terminal.integrated.fontFamily": "'JetBrainsMono Nerd Font'",
  "terminal.integrated.lineHeight": 1.0,
  "terminal.integrated.defaultProfile.linux": "zsh",
  "terminal.integrated.fontSize": 16,
  "terminal.integrated.fontWeight": 600,

  // git
  "git.enableSmartCommit": true,
  "git.confirmSync": false,
  "git.autofetch": true,
  "git.openRepositoryInParentFolders": "never",

  // settings cycler
  "settings.cycle": [
    {
      "id": "lineNumbers",
      "values": [
        {
          "editor.lineNumbers": "off"
        },
        {
          "editor.lineNumbers": "on"
        }
      ]
    }
  ],

  // source control
  "scm.diffDecorations": "all",

  // css
  "css.lint.unknownAtRules": "ignore",

  // php
  "php.suggest.basic": false,
  "php.validate.enable": false,
  "intelephense.telemetry.enabled": false,
  "intelephense.codeLens.implementations.enable": true,
  "intelephense.codeLens.overrides.enable": true,
  "intelephense.codeLens.parent.enable": true,
  "intelephense.codeLens.references.enable": true,
  "intelephense.codeLens.usages.enable": true,
  "intelephense.completion.fullyQualifyGlobalConstantsAndFunctions": true,
  "intelephense.compatibility.preferPsalmPhpstanPrefixedAnnotations": true,
  "intelephense.diagnostics.undefinedMethods": false,

  // prettier
  "prettier.tabWidth": 2,
  "prettier.printWidth": 120,
  "prettier.trailingComma": "none",
  "prettier.semi": false,
  "prettier.arrowParens": "avoid",
  "prettier.singleQuote": true,

  // blade formatter
  "bladeFormatter.format.noMultipleEmptyLines": true,
  "bladeFormatter.format.noSingleQuote": true,

  // laravel
  "laravel-pint.enable": true,

  // file specific
  "[blade]": {
    "editor.defaultFormatter": "shufo.vscode-blade-formatter"
  },
  "[php]": {
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "open-southeners.laravel-pint"
  },
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode"
  },

  "explorer.fileNesting.patterns": {
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "tsconfig.json": "tsconfig.*.json",
    "package.json": "package-lock.json, yarn.lock, pnpm-lock.yaml, bun.lockb",
    "*.sqlite": "${capture}.${extname}-*",
    "*.db": "${capture}.${extname}-*",
    "*.sqlite3": "${capture}.${extname}-*",
    "*.db3": "${capture}.${extname}-*",
    "*.sdb": "${capture}.${extname}-*",
    "*.s3db": "${capture}.${extname}-*"
  },

  "github.copilot.advanced": {}
}
